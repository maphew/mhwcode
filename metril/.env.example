# Trilium ETAPI credentials
# Copy this file to .env and fill in your values.
# Docs: https://github.com/zadam/trilium/wiki/ETAPI

# Base URL of your Trilium instance, e.g. http://localhost:8080
TRILIUM_HOST=http://localhost:8080

# ETAPI token — generate one in Trilium: Menu → Options → ETAPI
TRILIUM_TOKEN=your_token_here
